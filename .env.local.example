# Vite reads VITE_-prefixed vars. Copy to .env.local and fill in.
# Local Supabase (default ports remapped — see supabase/config.toml)
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Google OAuth — used by the local Supabase auth server, not the browser.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:54421/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# Gemini (used server-side via Edge Function once Assist mode is wired)
GEMINI_API_KEY=
