# Single env file consumed by Vite, Supabase CLI, and the Express server.
# Copy to .env and fill in. .env is git-ignored.
# Local Supabase (default ports remapped — see supabase/config.toml)
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Service role key — bypasses RLS. Used only by `npm run seed`.
# Run `supabase status -o env` and copy SERVICE_ROLE_KEY here. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini (used server-side via Edge Function once Assist mode is wired)
GEMINI_API_KEY=

# Express server (npm run dev:server). Defaults to 3000 if unset.
PORT=3000

# Resend — used by the Node server's /api/send-email route
RESEND_API_KEY=
RESEND_FROM="Orbit <noreply@example.com>"
