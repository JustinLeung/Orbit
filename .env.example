# Single env file consumed by Vite, Supabase CLI, and the Express server.
# Copy to .env and fill in. .env is git-ignored.
# Local Supabase (default ports remapped — see supabase/config.toml)
VITE_SUPABASE_URL=http://127.0.0.1:54421
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Service role key — bypasses RLS. Used by `npm run seed` and by the Express
# server's /api/auth/send-otp route (calls supabase.auth.admin.generateLink).
# Run `supabase status -o env` and copy SERVICE_ROLE_KEY here. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — powers /api/assist/clarify (conversational ticket capture).
# Server-side only. If unset, the new-ticket dialog returns 503 and the UI
# offers the manual form. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Express server (npm run dev:server). Defaults to 3000 if unset.
PORT=3000

# Resend — used by the Node server's /api/send-email and /api/auth/send-otp
# routes. Without RESEND_API_KEY, /api/auth/send-otp falls back to printing
# the code + magic link to the server console (dev only).
RESEND_API_KEY=
RESEND_FROM="Orbit <noreply@example.com>"
